# OmniBot v3 local development defaults
# Copy this file to .env if you want to override the built-in development-safe settings.

OMNIBOT_ENV=development
OMNIBOT_LOG_LEVEL=info
OMNIBOT_DATA_ROOT=data
OMNIBOT_SECRETS_DIR=secrets
OMNIBOT_BIND_HOST=127.0.0.1
OMNIBOT_PORT=8000

# Optional in development. If unset, the dashboard login defaults to admin/admin.
# OMNIBOT_ADMIN_USERNAME=admin
# OMNIBOT_ADMIN_PASSWORD=admin

# Optional if you want to override the local database DSN used by config loading.
# OMNIBOT_DB_DSN=postgresql://omnibot:omnibot@localhost:5432/omnibot